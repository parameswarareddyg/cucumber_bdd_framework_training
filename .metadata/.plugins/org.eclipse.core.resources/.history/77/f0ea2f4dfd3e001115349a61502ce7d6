package extentreports;

import java.io.File;
import java.time.LocalDateTime;
import java.time.format.DateTimeFormatter;
import java.util.Objects;

import com.aventstack.extentreports.ExtentReports;
import com.aventstack.extentreports.reporter.ExtentSparkReporter;
import com.aventstack.extentreports.reporter.configuration.Theme;

import constants.FrameworkConstants;

public class ExtentReport {
	private static ExtentReports extentReports;
	private static String reportDateTime;
	
	public static void initExtentReport()
	{
		if(Objects.isNull(extentReports))
		{
			extentReports = new ExtentReports();
			reportDateTime = getDateAndTime();
			ExtentSparkReporter spark = new ExtentSparkReporter(new File(FrameworkConstants.getReportspath()+reportDateTime+".html"));
			spark.config().setDocumentTitle("");
			spark.config().setReportName("");
			spark.config().setTheme(Theme.DARK);
			
		}
	}
	
	public static String getDateAndTime()
	{
		LocalDateTime now = LocalDateTime.now();
		DateTimeFormatter formatter = DateTimeFormatter.ofPattern("dd_MMM_yyyy_hh_mm_ss");
		String formatedDate = now.format(formatter);

		return formatedDate;
	}
}
