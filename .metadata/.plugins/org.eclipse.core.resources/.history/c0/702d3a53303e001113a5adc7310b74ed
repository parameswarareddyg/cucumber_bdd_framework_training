package utils;

import java.io.File;
import java.io.FileInputStream;
import java.util.LinkedHashMap;
import java.util.Map;

import org.apache.poi.hssf.usermodel.HSSFSheet;
import org.apache.poi.hssf.usermodel.HSSFWorkbook;

public class ExcelUtils {
	public static Map<String,String> readExcelData()
	{
		List<Map<String,String>> data =new LinkedHashMap<>();
		FileInputStream fileInputStream;
		try {
			File file = new File("src/test/resources/TestNG/testng.xml");
			fileInputStream = new FileInputStream(file);
			HSSFWorkbook workbook = new HSSFWorkbook();
			HSSFSheet sheet = workbook.getSheetAt(0);
			int rowCount = sheet.getPhysicalNumberOfRows();
			int columnCount = sheet.getRow(0).getPhysicalNumberOfCells();
			
			for(int i=1;i<rowCount;i++)
			{
				for(int j=0;j<columnCount;j++)
				{
					String mobilenumber = sheet.getRow(i).getCell(j).getStringCellValue();
					System.out.println("Mobile Number : "+mobilenumber);
					
				}
			}
			
		}
		catch(Exception e)
		{
			
		}
			
		
		return null;
	}
}
